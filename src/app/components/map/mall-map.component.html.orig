<div class="mb-8 px-6 pt-6">
  <h1 class="text-3xl font-bold font-display text-gray-900 tracking-tight">Interactive Mall Map</h1>
  <p class="text-blue-600 font-bold text-[10px] uppercase tracking-[0.2em] mt-1 italic">Explore the Ecosystem</p>
</div>

<div class="flex flex-col lg:flex-row h-[75vh] overflow-hidden bg-gray-50/50 rounded-3xl m-6 border border-gray-100 shadow-2xl shadow-gray-200/50 relative">
  <div class="flex-grow relative overflow-hidden bg-white group">
    <div class="absolute top-6 left-6 z-20 flex p-1 bg-white/80 backdrop-blur-md rounded-2xl shadow-xl border border-gray-100">
      <button 
        (click)="currentLevel = 0"
        [class.bg-blue-600]="currentLevel === 0"
        [class.text-white]="currentLevel === 0"
        class="px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all"
      >
        Ground
      </button>
      <button 
        (click)="currentLevel = 1"
        [class.bg-blue-600]="currentLevel === 1"
        [class.text-white]="currentLevel === 1"
        class="px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all"
      >
        Level 1
      </button>
    </div>

    <div class="h-full w-full overflow-auto cursor-grab active:cursor-grabbing p-20 map-viewport">
       <div class="relative w-[1200px] h-[1200px] bg-white rounded-[4rem] border border-gray-100 shadow-inner overflow-hidden pattern-dots">
         <div 
           *ngFor="let shop of levelShops" 
           class="absolute w-16 h-16 rounded-2xl border-2 border-transparent bg-white shadow-lg flex items-center justify-center cursor-pointer hover:scale-125 hover:border-blue-500 hover:z-30 transition-all duration-300 group/node shadow-blue-500/5"
           [style.top.%]="shop.location.pos?.y || 20" 
           [style.left.%]="shop.location.pos?.x || 30"
           (click)="selectShop(shop)"
         >
           <span class="text-xs font-black text-gray-900">{{ shop.boxNumber }}</span>
           <div class="absolute -top-12 left-1/2 -translate-x-1/2 px-4 py-2 bg-gray-900 text-white text-[10px] font-bold rounded-xl opacity-0 group-hover/node:opacity-100 pointer-events-none transition-opacity whitespace-nowrap shadow-xl">
             {{ shop.currentTenant?.name || 'Available Box' }}
           </div>
           <div class="absolute inset-0 bg-blue-500/5 rounded-2xl opacity-0 group-hover/node:opacity-100 transition-opacity"></div>
         </div>
       </div>
    </div>
  </div>

  <div class="w-full lg:w-96 p-8 bg-white/80 backdrop-blur-md border-l border-gray-100 flex flex-col animate-fade" *ngIf="selectedShop">
    <div class="flex justify-between items-start mb-10">
      <div>
        <h2 class="text-2xl font-black font-display text-gray-900 leading-tight mb-2">{{ selectedShop.currentTenant?.name || 'Vacant Space' }}</h2>
        <span class="text-[10px] font-black uppercase tracking-widest text-blue-600 bg-blue-50 px-3 py-1 rounded-lg">Box {{ selectedShop.boxNumber }}</span>
      </div>
      <button (click)="selectedShop = null" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors">✕</button>
    </div>

    <div class="space-y-8 flex-grow">
      <div class="p-6 bg-gray-50 rounded-2xl">
         <p class="text-[10px] uppercase font-bold text-gray-400 tracking-widest mb-4 italic">About this location</p>
         <p class="text-sm text-gray-700 leading-relaxed">{{ selectedShop.type }} focus with premium visibility in {{ selectedShop.location.zone }}.</p>
      </div>

      <div class="grid grid-cols-1 gap-4">
        <button class="w-full py-4 bg-gray-900 text-white font-black uppercase tracking-[0.2em] rounded-2xl hover:bg-black transition-all active:scale-[0.98] shadow-xl shadow-gray-100">
           Visit Storefront
        </button>
        <button class="w-full py-4 bg-white border-2 border-gray-100 text-gray-900 font-black uppercase tracking-[0.2em] rounded-2xl hover:border-blue-500 hover:text-blue-600 transition-all active:scale-[0.98]">
           View Catalog
        </button>
      </div>
    </div>
  </div>
  
  <div class="absolute bottom-8 left-8 z-20 flex gap-4" *ngIf="!selectedShop">
     <div class="flex items-center gap-2 bg-white/80 backdrop-blur-md px-4 py-2 rounded-full border border-gray-100 text-[10px] font-bold text-gray-400">
       <span class="w-3 h-3 rounded-full bg-blue-500"></span> Current Tenant
     </div>
     <div class="flex items-center gap-2 bg-white/80 backdrop-blur-md px-4 py-2 rounded-full border border-gray-100 text-[10px] font-bold text-gray-400">
       <span class="w-3 h-3 rounded-full bg-gray-100 border border-gray-200"></span> Available
     </div>
  </div>
</div>
