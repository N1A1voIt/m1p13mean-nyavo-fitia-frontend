<div class="flex h-[calc(100vh-12rem)] gap-8">
  <div class="flex-grow flex flex-col glass bg-white border-gray-100 shadow-sm overflow-hidden animate-fade">
    <div class="p-6 border-b border-gray-50 bg-gray-50/50">
       <div class="relative max-w-2xl mx-auto">
         <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
         <input 
           type="text" 
           [(ngModel)]="searchQuery" 
           (input)="filterProducts()"
           placeholder="Search products or scan SKU..." 
           class="w-full bg-white border border-gray-200 py-3 pl-12 pr-4 rounded-xl text-gray-900 focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500 outline-none transition-all placeholder:italic"
         >
       </div>
    </div>
    
    <div class="flex-grow overflow-y-auto p-8">
      <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4">
        <div 
          *ngFor="let p of filteredProducts" 
          (click)="addToCart(p)"
          class="group p-6 bg-gray-50 border border-transparent rounded-2xl cursor-pointer hover:bg-white hover:border-pink-200 hover:shadow-xl hover:shadow-pink-500/5 transition-all duration-300 text-center relative overflow-hidden active:scale-95"
        >
          <div class="text-3xl mb-4 group-hover:scale-110 transition-transform">📦</div>
          <p class="font-bold text-gray-900 leading-tight mb-2 truncate px-2">{{ p.name }}</p>
          <p class="text-pink-600 font-black font-display text-lg">{{ p.price | currency:'MGA':'symbol':'1.0-0' }}</p>
          <div class="mt-3 flex justify-center">
             <span 
              class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full"
              [ngClass]="p.stock < 10 ? 'bg-red-100 text-red-600' : 'bg-gray-200 text-gray-400'"
             >
               Stock: {{ p.stock }}
             </span>
          </div>
        </div>
      </div>
      
      <div *ngIf="filteredProducts.length === 0" class="flex flex-col items-center justify-center h-full opacity-20">
         <div class="text-6xl mb-4">🔍</div>
         <p class="text-xl font-bold italic">No matching products found</p>
      </div>
    </div>
  </div>

  <div class="w-96 flex flex-col glass bg-white border-gray-100 shadow-xl overflow-hidden animate-fade" style="animation-delay: 0.1s">
    <div class="p-6 border-b border-gray-100 bg-gray-900 text-white">
      <h3 class="text-lg font-black font-display uppercase tracking-widest italic flex items-center gap-2">
        <span>🛒</span> Current Ticket
      </h3>
    </div>
    
    <div class="flex-grow overflow-y-auto p-6 space-y-4">
      <div *ngFor="let item of cart" class="flex items-center gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors group">
        <div class="flex-grow min-w-0">
          <p class="font-bold text-gray-900 truncate leading-tight">{{ item.name }}</p>
          <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tight">{{ item.quantity }} x {{ item.price | currency:'MGA':'symbol':'1.0-0' }}</p>
        </div>
        <div class="text-right">
          <p class="font-black text-gray-900">{{ item.total | currency:'MGA':'symbol':'1.0-0' }}</p>
          <button (click)="removeFromCart(item)" class="text-red-400 hover:text-red-600 font-bold text-xs">Remove</button>
        </div>
      </div>
      
      <div *ngIf="cart.length === 0" class="h-full flex flex-col items-center justify-center opacity-20 border-2 border-dashed border-gray-100 rounded-3xl m-2">
         <div class="text-4xl mb-2 italic font-display">Cart Empty</div>
      </div>
    </div>
    
    <div class="p-6 bg-gray-50 border-t border-gray-100 space-y-4">
      <div class="flex justify-between items-center text-gray-400 font-bold text-sm">
        <span>SUBTOTAL</span>
        <span>{{ subtotal | currency:'MGA':'symbol':'1.0-0' }}</span>
      </div>
      <div class="flex justify-between items-center text-gray-900 font-black text-2xl font-display">
        <span>TOTAL</span>
        <span class="text-pink-600 underline decoration-pink-200 underline-offset-4">{{ subtotal | currency:'MGA':'symbol':'1.0-0' }}</span>
      </div>
      
      <div class="grid grid-cols-1 gap-3 pt-4">
        <button 
          (click)="checkout()"
          [disabled]="cart.length === 0"
          class="w-full py-4 bg-gray-900 text-white font-black uppercase tracking-[0.2em] rounded-2xl hover:bg-black transition-all active:scale-[0.98] shadow-xl shadow-gray-200 disabled:opacity-30 disabled:cursor-not-allowed"
        >
          Finalize Transaction
        </button>
        <div class="grid grid-cols-2 gap-2">
           <button class="py-3 bg-white border border-gray-200 text-gray-500 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-indigo-50 hover:text-indigo-600 transition-all">Mobile Money</button>
           <button class="py-3 bg-white border border-gray-200 text-gray-500 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-pink-50 hover:text-pink-600 transition-all">Gift Card</button>
        </div>
      </div>
    </div>
  </div>
</div>
